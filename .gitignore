.venv/
.vscode/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Generated benchmark data and outputs are reproducible and should not be committed.
data/processed/*
!data/processed/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep
outputs/checkpoints/*
!outputs/checkpoints/.gitkeep
outputs/tables/*
!outputs/tables/.gitkeep
!outputs/tables/pinn_inverse_v0_ablation_summary.json
!outputs/tables/pinn_identifiability_summary.json
!outputs/tables/pinn_identifiability_correlation.csv
outputs/pinn_inverse_v0/*
outputs/pinn_inverse_v0_smoke/*
outputs/pinn_inverse_v1/*
outputs/pinn_inverse_v1_smoke/*
!outputs/tables/pinn_inverse_v1_summary.json
outputs/pinn_inverse_v1_1/*
outputs/pinn_inverse_v1_1_smoke/*
!outputs/tables/pinn_inverse_v1_1_summary.json

*.npz
*.npy
*.pt
*.pth
*.ckpt
